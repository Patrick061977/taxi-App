<?xml version="1.0" encoding="utf-8"?>
<!-- v6.62.202: Schicht-Healthcheck nach Driver-Login.
     Patrick (02.05.2026): 'Bei neuen Fahrern auf neuem Handy soll alles geprueft werden — GPS, Berechtigung, alles.'
     Ueberprueft 8 Punkte und bietet pro fehlgeschlagenem Check 'Jetzt fixen'-Button. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E293B"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔧 Schicht-Healthcheck"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/healthcheck_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Wir prüfen ob alles eingestellt ist damit Aufträge ankommen."
            android:textColor="#94A3B8"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_autofix_all"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:backgroundTint="#3B82F6"
            android:text="🚀 Alles automatisch fixen"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="10dp" />
    </LinearLayout>

    <!-- Check-Liste -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/healthcheck_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />
    </ScrollView>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E293B"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/healthcheck_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center"
            android:text="Prüfe…"
            android:textColor="#CBD5E1"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_continue"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#10B981"
            android:enabled="false"
            android:text="Schicht starten"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_skip"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Trotzdem weiter (auf eigenes Risiko)"
            android:textColor="#64748B"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
