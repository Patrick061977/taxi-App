<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E293B"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚗 Fahrzeug wählen"
            android:textColor="#F8FAFC"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_logged_in_as"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Angemeldet"
            android:textColor="#94A3B8"
            android:textSize="13sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_vehicles"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="14dp"
        android:clipToPadding="false" />

    <!-- v6.51.0: Admin-Modus für Patrick auf 2. Handy (S9+) — kein Fahrzeug,
         nur Anrufliste + Buchungs-Anlage. Sichtbarkeit per /admins/{uid} in Firebase. -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_admin_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="14dp"
        android:padding="14dp"
        android:text="👤 Admin-Modus (kein Fahrzeug)"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:backgroundTint="#7C3AED"
        app:cornerRadius="12dp" />

    <ProgressBar
        android:id="@+id/vehicle_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"
        android:indeterminateTint="#10B981"
        android:visibility="gone" />
</LinearLayout>
