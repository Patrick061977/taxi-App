{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "rides": {
      ".read": true,
      ".write": "auth != null",
      ".indexOn": ["pickupTimestamp", "status"]
    },

    "drivers": {
      ".read": true,
      ".write": "auth != null"
    },

    "tracking": {
      ".read": true,
      ".write": "auth != null"
    },

    "vehicles": {
      ".read": true,
      ".write": "auth != null"
    },

    "settings": {
      ".read": "auth != null",
      ".write": "auth != null",
      "calendarExport": {
        ".read": true
      },
      "telegram": {
        "pending": {
          ".read": true
        },
        "botlog": {
          ".read": true
        }
      },
      "buchenLog": {
        ".read": true,
        ".write": true,
        ".indexOn": ["time"]
      },
      "tarif": {
        ".read": true
      }
    },

    "logs": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "bookingRequests": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "calendarEvents": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "pois": {
      ".read": true,
      ".write": "auth != null"
    },

    "geocache": {
      ".read": true,
      ".write": true
    },

    "vehicleShifts": {
      ".read": true,
      ".write": "auth != null"
    },

    "shifts": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "scripts": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "analytics": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "customers": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "activity_log": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "callHistory": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["timestamp"]
    },

    "hotelCalendars": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "hotelInvoices": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "cancellations": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
