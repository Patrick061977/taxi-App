<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:keepScreenOn="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E293B"
        app:elevation="0dp">

        <!-- v6.47.0: Schlanke Toolbar — Hamburger links, Titel + Status, Schicht-Stats kompakt -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_menu"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="☰"
                android:textColor="#F8FAFC"
                android:textSize="26sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_app_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🚕 Funk Taxi — Fahrer"
                    android:textColor="#F8FAFC"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_vehicle_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp"
                    android:text="Fahrzeug…"
                    android:textColor="#94A3B8"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_shift_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#475569"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp"
                android:text="⏸ Aus"
                android:textColor="#F8FAFC"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- v6.47.8: Schicht-Stats-Banner KOMPLETT WEG - Patrick will den Platz für Aufträge.
             Timer + Verdienst sind in StatsActivity (Hamburger-Menü → Statistik) zugänglich.
             Felder bleiben als unsichtbare Keepalive für die Activity (sonst NPE). -->
        <LinearLayout
            android:id="@+id/shift_stats_row"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_shift_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tv_today_earnings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tv_shift_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_rides"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false"
        android:paddingBottom="180dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚖"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Keine offenen Aufträge"
            android:textColor="#F8FAFC"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Schicht via ☰ Menü starten."
            android:textColor="#94A3B8"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Bottom-Aktion-Bar: Anrufliste + EINSTEIGER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#1E293B"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_call_log"
            android:layout_width="64dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:text="📞"
            android:textSize="22sp"
            app:backgroundTint="#3B82F6"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_einsteiger"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="🚖 EINSTEIGER"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#F97316"
            app:cornerRadius="14dp" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
