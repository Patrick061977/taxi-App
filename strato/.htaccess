RewriteEngine On

# HTTPS erzwingen
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# v6.62.609: www-Subdomain auf naked Domain umleiten.
# Patrick (11.05.): Firebase Phone Auth blockt mit "auth/captcha-check-failed:
# Hostname match not found" wenn Seite von www.umwelt-taxi-insel-usedom.de
# kommt — nur die naked Domain ist in Firebase Auth "Authorized Domains".
# Loesung: 301-Redirect www → naked → Firebase-Auth funktioniert IMMER.
RewriteCond %{HTTP_HOST} ^www\.umwelt-taxi-insel-usedom\.de$ [NC]
RewriteRule ^(.*)$ https://umwelt-taxi-insel-usedom.de/$1 [L,R=301]

# umwelt-taxi-insel-usedom.de -> /Taxi-App
RewriteCond %{HTTP_HOST} ^(www\.)?umwelt-taxi-insel-usedom\.de$ [NC]
RewriteCond %{REQUEST_URI} !^/Taxi-App/
RewriteRule ^(.*)$ /Taxi-App/$1 [L]

# taschenlokal.de -> /taschenlokal-de
RewriteCond %{HTTP_HOST} ^(www\.)?taschenlokal\.de$ [NC]
RewriteCond %{REQUEST_URI} !^/taschenlokal-de/
RewriteRule ^(.*)$ /taschenlokal-de/$1 [L]

# strandurlaub-heringsdorf.de -> /strandurlaub-heringsdorf-de
RewriteCond %{HTTP_HOST} ^(www\.)?strandurlaub-heringsdorf\.de$ [NC]
RewriteCond %{REQUEST_URI} !^/strandurlaub-heringsdorf-de/
RewriteRule ^(.*)$ /strandurlaub-heringsdorf-de/$1 [L]

# v6.62.613: keinbockzulaufen.de -> Taxi-App (merkbare Marketing-Domain).
# Patrick (11.05.): "Auto vorbeifahrt sieht Aufkleber, kann sich keinbockzulaufen.de
# leichter merken als umwelt-taxi-insel-usedom.de".
#
# v6.62.869 (Patrick 22.05. 17:45): "Tagesplan + buchen.html funktionieren nicht
# auf keinbockzulaufen.de". Vorher leitete JEDE Anfrage auf landing.html — also
# tagesplan.html → landing.html (= 200 landing-Inhalt mit falscher URL). Fix:
#  - Root (/) → /Taxi-App/landing.html (Standard-Einstieg)
#  - Alle anderen Pfade (z.B. /tagesplan.html) → /Taxi-App/{path} (identisch zu
#    umwelt-taxi-insel-usedom.de-Mapping)
RewriteCond %{HTTP_HOST} ^(www\.)?keinbockzulaufen\.de$ [NC]
RewriteCond %{REQUEST_URI} !^/Taxi-App/
RewriteCond %{REQUEST_URI} ^/?$
RewriteRule ^(.*)$ /Taxi-App/landing.html [L]

RewriteCond %{HTTP_HOST} ^(www\.)?keinbockzulaufen\.de$ [NC]
RewriteCond %{REQUEST_URI} !^/Taxi-App/
RewriteRule ^(.*)$ /Taxi-App/$1 [L]
