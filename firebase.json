{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": ".",
    "headers": [
      {
        "source": "app-download.html",
        "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
      },
      {
        "source": "**/*.apk",
        "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
      }
    ],
    "ignore": [
      "firebase.json",
      "**/node_modules/**",
      "functions/**",
      "android/**",
      "www/**",
      ".claude/**",
      ".git/**",
      ".github/**",
      "tools/**",
      "google-apps-script/**",
      "macrodroid/**",
      "strato/**",
      "strato-upload/**",
      "strato-deploy.zip",
      "*.py",
      "*.txt",
      "*.md",
      "*.sh",
      "*.backup*"
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}
