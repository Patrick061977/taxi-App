<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:keepScreenOn="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E293B"
        app:elevation="0dp">

        <!-- v6.50.0: Update-Banner — wird angezeigt wenn neuere Version auf GitHub-Releases -->
        <LinearLayout
            android:id="@+id/update_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#10B981"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/update_banner_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📥 Update verfügbar"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/update_banner_btn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Installieren"
                android:textColor="#10B981"
                android:textSize="12sp"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="18dp" />
        </LinearLayout>

        <!-- v6.62.369: Driver-Banner "Frei bis HH:MM · Naechste Vorbestellung HH:MM" -->
        <!-- Patrick (06.05. 14:30): "wie kriegen wir das dem Fahrer uebermittelt dass irgendwann ne Fahrt auf ihn zukommt" -->
        <!-- v6.62.764 (Patrick 16.05. 08:15 "das ist alles zu gross irgendwie"):
             Banner kompakter — Padding 8→5, Text 14→12 / 12→10. Spart vertikal ~12dp -->
        <LinearLayout
            android:id="@+id/freebusy_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#059669"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/freebusy_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🟢 Frei für Sofort-Anfragen"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/freebusy_next"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:textColor="#D1FAE5"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- v6.47.0: Schlanke Toolbar — Hamburger links, Titel + Status, Schicht-Stats kompakt -->
        <!-- v6.62.764 (Patrick 16.05. 08:15 "alles zu gross"): Toolbar
             kompakter — Padding 10→6, Title 17→15, DriverName 13→11, VehicleInfo 11→10 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="6dp"
            android:paddingEnd="16dp"
            android:paddingBottom="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_menu"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="☰"
                android:textColor="#F8FAFC"
                android:textSize="22sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_app_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🚕 Funk Taxi — Fahrer"
                    android:textColor="#F8FAFC"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_driver_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text=""
                    android:textColor="#10B981"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_vehicle_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp"
                    android:text="Fahrzeug…"
                    android:textColor="#94A3B8"
                    android:textSize="10sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_shift_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#475569"
                android:paddingStart="7dp"
                android:paddingTop="3dp"
                android:paddingEnd="7dp"
                android:paddingBottom="3dp"
                android:text="⏸ Aus"
                android:textColor="#F8FAFC"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- v6.47.8: Schicht-Stats-Banner KOMPLETT WEG - Patrick will den Platz für Aufträge.
             Timer + Verdienst sind in StatsActivity (Hamburger-Menü → Statistik) zugänglich.
             Felder bleiben als unsichtbare Keepalive für die Activity (sonst NPE). -->
        <LinearLayout
            android:id="@+id/shift_stats_row"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_shift_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tv_today_earnings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tv_shift_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- v6.62.26 / v6.62.734: Grosser Pause-Banner — IMMER ueber Auftraegen sichtbar (elevation 12dp).
         Patrick (15.05. 13:35): "Wenn ein Auftrag drueber liegt, sehe ich nicht dass ich nicht angemeldet bin." -->
    <TextView
        android:id="@+id/tv_pause_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="?attr/actionBarSize"
        android:background="#F59E0B"
        android:elevation="12dp"
        android:gravity="center"
        android:padding="18dp"
        android:text="⏸  DU BIST AUF PAUSE  —  Tippen zum Online schalten"
        android:textColor="#1F2937"
        android:textSize="17sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- v6.62.734: nestedScrollingEnabled=true damit Scroll bei 2+ Auftraegen funktioniert (Patrick 15.05. 13:35) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_rides"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false"
        android:paddingBottom="180dp"
        android:nestedScrollingEnabled="true"
        android:overScrollMode="always"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚖"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Keine offenen Aufträge"
            android:textColor="#F8FAFC"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Schicht via ☰ Menü starten."
            android:textColor="#94A3B8"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Bottom-Aktion-Bar: Anrufliste + EINSTEIGER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#1E293B"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_call_log"
            android:layout_width="64dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:text="📞"
            android:textSize="22sp"
            app:backgroundTint="#3B82F6"
            app:cornerRadius="14dp" />

        <!-- v6.63.267: btn_quick_pay entfernt — Patrick "haben wir ja im Hamburger-Menue".
             Quick-Pay bleibt erreichbar via ☰ → '💳 Vorkasse-Link (Stripe)'. -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_einsteiger"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="🚖 EINSTEIGER"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#F97316"
            app:cornerRadius="14dp" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
