<?xml version="1.0" encoding="utf-8"?>
<!-- v6.62.521: Patrick (09.05. 09:57): "das ist alles ein bischen zu gross".
     Padding, Textgrößen, Button-Höhen und Margins ~25-30% reduziert,
     damit auf dem Driver-Phone mehr Inhalt sichtbar ist. Tap-Targets
     bleiben oberhalb der 44dp-Material-Mindestgröße. -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="#1E293B"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#F59E0B"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:text="🆕 NEU"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- v6.63.258 (Patrick 10.06. 06:23): BEZAHLT-Badge wenn Kunde Stripe-Vorkasse
                 schon abgeschlossen hat. Fahrer kassiert dann NICHT mehr Bar/Karte.
                 v6.63.506 (Patrick 28.06.): größer + prominenter (14sp, mehr Padding). -->
            <TextView
                android:id="@+id/tv_paid_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="#059669"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="💵 BEZAHLT"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_pickup_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sofort"
                android:textColor="#F8FAFC"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_customer_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Kundenname"
            android:textColor="#F8FAFC"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_pickup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="📍 Abholort"
            android:textColor="#CBD5E1"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_destination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="🎯 Zielort"
            android:textColor="#CBD5E1"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_price_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="💰 -- € · 🛣️ -- km"
            android:textColor="#94A3B8"
            android:textSize="11sp" />

        <!-- v6.62.303: Live-ETA-Banner | v6.62.502: kompakter (16sp) | v6.62.521: 14sp -->
        <TextView
            android:id="@+id/tv_live_eta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:padding="5dp"
            android:background="#1E40AF"
            android:gravity="center"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Annehmen/Ablehnen — bei NEU/ZUGEWIESEN/SOFORT/VORBESTELLT -->
        <LinearLayout
            android:id="@+id/action_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reject"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:text="❌ Ablehnen"
                android:textAllCaps="false"
                android:textColor="#F8FAFC"
                android:textSize="13sp"
                app:backgroundTint="#475569"
                app:cornerRadius="9dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_accept"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="5dp"
                android:layout_weight="2"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:text="✅ Annehmen"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#10B981"
                app:cornerRadius="9dp" />
        </LinearLayout>

        <!-- v6.43.0: Aktive-Fahrt-Toolbar — bei accepted/on_way/arrived/picked_up -->
        <LinearLayout
            android:id="@+id/active_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_navigate"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="3dp"
                    android:layout_weight="1"
                    android:text="🧭"
                    android:textSize="18sp"
                    app:backgroundTint="#3B82F6"
                    app:cornerRadius="9dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_call"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    android:layout_weight="1"
                    android:text="📞"
                    android:textSize="18sp"
                    app:backgroundTint="#10B981"
                    app:cornerRadius="9dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sms_track"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="3dp"
                    android:layout_weight="1"
                    android:text="💬"
                    android:textSize="18sp"
                    app:backgroundTint="#F59E0B"
                    app:cornerRadius="9dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_status_next"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="4"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp"
                    android:text="▶ Bin unterwegs"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:backgroundTint="#10B981"
                    app:cornerRadius="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel_ride"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingLeft="0dp"
                    android:paddingRight="0dp"
                    android:text="✗"
                    android:textAllCaps="false"
                    android:textColor="#F8FAFC"
                    android:textSize="20sp"
                    app:backgroundTint="#EF4444"
                    app:cornerRadius="10dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
