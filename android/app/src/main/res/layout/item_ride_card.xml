<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#1E293B"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Status + Zeit -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#F59E0B"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="🆕 NEU"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_pickup_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sofort"
                android:textColor="#F8FAFC"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Kundenname -->
        <TextView
            android:id="@+id/tv_customer_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Kundenname"
            android:textColor="#F8FAFC"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Adressen -->
        <TextView
            android:id="@+id/tv_pickup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="📍 Abholort"
            android:textColor="#CBD5E1"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_destination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="🎯 Zielort"
            android:textColor="#CBD5E1"
            android:textSize="13sp" />

        <!-- Preis + Distanz -->
        <TextView
            android:id="@+id/tv_price_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="💰 -- € · 🛣️ -- km"
            android:textColor="#94A3B8"
            android:textSize="12sp" />

        <!-- Action-Buttons -->
        <LinearLayout
            android:id="@+id/action_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reject"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="❌ Ablehnen"
                android:textColor="#F8FAFC"
                app:backgroundTint="#475569"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_accept"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="2"
                android:text="✅ Annehmen"
                android:textColor="#FFFFFF"
                app:backgroundTint="#10B981"
                app:cornerRadius="10dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
